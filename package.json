		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^26.0.0",
		"daisyui": "^5.5.23",
		"dotenv": "^17.4.2",
